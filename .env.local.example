# ---------------------------------------------------------------------------
# Copy this file to `.env.local` for local dev, and add the same keys to Vercel.
# Find these values in your Supabase dashboard: Project Settings → API.
# ---------------------------------------------------------------------------

# Safe to expose to the browser (used by the client SDK). NOT secret.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: base URL used for auth email redirect links.
# Locally: http://localhost:3000  |  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
